@model SchoolEduERP.Helpers.PaginatedList<SchoolEduERP.Models.Domain.Subject>
@using Microsoft.AspNetCore.Routing
@{
    ViewData["Title"] = "Subjects";
    ViewData["UserRole"] = "Admin";
    var standards       = ViewBag.Standards as List<int> ?? new List<int>();
    var selectedStd     = ViewBag.SelectedStandard as int?;
    var searchTerm      = ViewBag.SearchTerm as string ?? "";
    var routeVals       = new RouteValueDictionary(new { standard = selectedStd, search = searchTerm });
    ViewData["RouteValues"] = routeVals;
}

<div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
    <div>
        <h1 class="text-2xl md:text-3xl font-bold text-slate-900 dark:text-white tracking-tight">Subject Management</h1>
        <p class="text-slate-500 dark:text-slate-400 mt-1">Manage subjects assigned to each standard.</p>
    </div>
    <a asp-action="Create" class="bg-primary hover:bg-primary/90 text-white font-semibold py-2.5 px-6 rounded-xl transition-all shadow-lg shadow-primary/20 flex items-center gap-2 w-fit">
        <span class="material-symbols-outlined text-[20px]">add</span> Add Subject
    </a>
</div>

@* Filter bar *@
<div class="bg-white dark:bg-surface-dark rounded-xl shadow-sm border border-slate-200 dark:border-slate-700 p-4 mb-6">
    <form method="get" class="flex flex-wrap items-end gap-4">
        <div>
            <label class="block text-xs font-semibold text-slate-500 mb-1">Standard</label>
            <select name="standard" class="rounded-lg border-slate-200 bg-slate-50 text-sm py-2 px-3 focus:ring-primary focus:border-primary min-w-[140px]">
                <option value="">All Standards</option>
                @foreach (var s in standards)
                {
                    <option value="@s" selected="@(selectedStd == s)">Standard @s</option>
                }
            </select>
        </div>
        <div>
            <label class="block text-xs font-semibold text-slate-500 mb-1">Search</label>
            <input name="search" value="@searchTerm" placeholder="Subject name or code…"
                   class="rounded-lg border-slate-200 bg-slate-50 text-sm py-2 px-3 focus:ring-primary focus:border-primary min-w-[200px]" />
        </div>
        <button type="submit" class="bg-primary text-white px-4 py-2 rounded-lg text-sm font-bold hover:bg-primary/90">
            <span class="material-symbols-outlined !text-[16px] align-middle mr-1">search</span> Search
        </button>
        <a asp-action="Index" class="text-sm text-slate-500 hover:text-primary font-medium px-3 py-2">Clear</a>
    </form>
</div>

<div class="bg-white dark:bg-surface-dark rounded-xl shadow-sm border border-slate-200 dark:border-slate-700 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead>
                <tr class="bg-slate-50 dark:bg-surface-dark-hover text-slate-500 dark:text-slate-400 text-xs font-bold uppercase tracking-wider">
                    <th class="px-6 py-3">Standard</th>
                    <th class="px-6 py-3">Subject Name</th>
                    <th class="px-6 py-3">Code</th>
                    <th class="px-6 py-3">Teacher</th>
                    <th class="px-6 py-3 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-700">
                @foreach (var s in Model)
                {
                    <tr class="hover:bg-slate-50/50 dark:hover:bg-surface-dark-hover/50 transition-colors">
                        <td class="px-6 py-4">
                            <span class="bg-primary/10 text-primary text-xs font-bold px-2 py-1 rounded">Std @s.Standard</span>
                        </td>
                        <td class="px-6 py-4 font-semibold dark:text-slate-100">@s.Name</td>
                        <td class="px-6 py-4 font-mono text-sm text-slate-500 dark:text-slate-400">@(s.Code ?? "-")</td>
                        <td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-300">
                            @if (s.Teacher != null)
                            {
                                <span class="flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[16px] text-slate-400">person</span>
                                    @s.Teacher.FirstName @s.Teacher.LastName
                                </span>
                            }
                            else
                            {
                                <span class="text-slate-400">Unassigned</span>
                            }
                        </td>
                        <td class="px-6 py-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <a asp-action="Edit" asp-route-id="@s.Id"
                                   class="flex items-center gap-1 text-xs font-semibold text-primary hover:text-primary/80 bg-primary/10 hover:bg-primary/20 px-3 py-1.5 rounded-lg transition-colors">
                                    <span class="material-symbols-outlined text-[16px]">edit</span> Edit
                                </a>
                                <form asp-action="Delete" method="post" class="inline delete-subject-form" 
                                      data-id="@s.Id" 
                                      onsubmit="return false;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@s.Id" />
                                    <button type="submit"
                                            class="flex items-center gap-1 text-xs font-semibold text-red-600 hover:text-red-800 bg-red-50 hover:bg-red-100 px-3 py-1.5 rounded-lg transition-colors delete-btn">
                                        <span class="material-symbols-outlined text-[16px]">delete</span> Delete
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="px-6 py-12 text-center">
                            <span class="material-symbols-outlined text-4xl text-slate-300 block mb-2">search_off</span>
                            <span class="text-slate-400 dark:text-slate-500">No subjects match your filters.</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @await Html.PartialAsync("_Pagination", Model)
</div>

@section Scripts {
<script>
    document.querySelectorAll('.delete-subject-form').forEach(function(form) {
        form.addEventListener('submit', function(e) {
            e.preventDefault(); // Stop normal form submission
            
            if (!confirm('Are you sure you want to delete this subject?')) {
                return;
            }

            var submitBtn = this.querySelector('.delete-btn');
            var originalHtml = submitBtn.innerHTML;
            
            // Show loading state
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="material-symbols-outlined text-[16px] animate-spin">refresh</span>...';

            var formData = new FormData(this);

            fetch(this.action, {
                method: 'POST',
                body: formData,
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    var row = this.closest('tr');
                    
                    // Show dynamic success toast/alert
                    var alertHtml = '<div class="alert-auto-dismiss mb-4 p-4 rounded-xl bg-red-50 border border-red-200 text-red-800 flex items-center gap-3 transition-opacity duration-500">' +
                        '<span class="material-symbols-outlined">delete</span>' +
                        '<div><p class="font-bold text-sm">Deleted</p><p class="text-xs opacity-90">' + data.message + '</p></div>' +
                        '</div>';
                    
                    document.querySelector('.overflow-hidden').insertAdjacentHTML('beforebegin', alertHtml);

                    // Fade out row and remove
                    row.style.transition = "opacity 0.3s ease";
                    row.style.opacity = 0;
                    setTimeout(function() { row.remove(); }, 300);

                    // Auto dismiss toast
                    setTimeout(function() {
                        document.querySelectorAll('.alert-auto-dismiss').forEach(a => {
                            a.style.opacity = '0';
                            setTimeout(() => a.remove(), 500);
                        });
                    }, 3000);
                } else {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalHtml;
                    alert('Error: ' + data.message);
                }
            })
            .catch(error => {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalHtml;
                alert('An error occurred while deleting the subject.');
            });
        });
    });
</script>
}
